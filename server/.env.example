# Copy this to .env and fill in real values. NEVER commit .env.

# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@host:5432/oms_db"

# JWT access token — short-lived (15 minutes)
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET
JWT_EXPIRES_IN="15m"

# Refresh token — long-lived (30 days), separate secret
REFRESH_TOKEN_SECRET=REPLACE_WITH_ANOTHER_STRONG_RANDOM_SECRET
REFRESH_TOKEN_EXPIRES_DAYS=30

PORT=5000
NODE_ENV=production

# Comma-separated allowed frontend origins
CLIENT_URL=https://yourdomain.com

# Email — use Resend/SendGrid/SES in production, Mailtrap in dev
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
EMAIL_FROM="OMS Portal <noreply@yourdomain.com>"
